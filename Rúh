---====== Khởi tạo Spawner ======---
local spawner = loadstring(game:HttpGet("https://raw.githubusercontent.com/VoorPhale012/Fogroom/refs/heads/main/Wwwhyyyyil"))()

local workspace = game:GetService("Workspace")
local players = game:GetService("Players")
local localPlayer = players.LocalPlayer

---====== Hàm tạo Invisible Entity ======---
local function SpawnInvisible()
    local entity = spawner.Create({
        Entity = {
            Name = "Invisible Entity",
            Asset = "rbxassetid://104261822446449",
            HeightOffset = 0
        },
        Lights = {
            Flicker = { Enabled = true, Duration = 10 },
            Shatter = false,
            Repair = false
        },
        Earthquake = { Enabled = true },
        CameraShake = {
            Enabled = true,
            Range = 100,
            Values = {0.1, 0.1, 0.1, 0.1}
        },
        Movement = {
            Speed = 500,
            Delay = 0.5,
            Reversed = true
        },
        Rebounding = {
            Enabled = false,
            Type = "Ambush",
            Min = 1, Max = 1, Delay = 2
        },
        Damage = { Enabled = false, Range = 40, Amount = 1 },
        Crucifixion = { Enabled = false, Range = 40, Resist = false, Break = true },
        Death = {
            Type = "Guiding",
            Hints = {"Death", "Hints", "Go", "Here"},
            Cause = ""
        }
    })

    entity:SetCallback("OnSpawned", function()
        task.wait(0.1)
        local model = workspace:FindFirstChild("Invisible Entity")
        if not model then return end

        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("PointLight") or v:IsA("ParticleEmitter") or v:IsA("SurfaceLight") or v:IsA("SpotLight") then
                v:Destroy()
            end
            if v:IsA("BasePart") then
                v.Transparency = 1
                v.CanCollide = false
            end
        end
    end)

    entity:Run()
end

---====== Hàm hỗ trợ âm thanh (Custom Assets) ======---
local function GitAud(soundgit, filename)
    local FileName = filename .. ".mp3"
    if not isfile(FileName) then
        writefile(FileName, game:HttpGet(soundgit))
    end
    return (getcustomasset or getsynasset)(FileName)
end

local function CustomGitSound(parent, soundlink, vol, name, minRoll, maxRoll)
    local sound = Instance.new("Sound")
    sound.SoundId = GitAud(soundlink, name)
    sound.Parent = parent
    sound.Volume = vol
    sound.PlaybackSpeed = 1
    sound.Name = name
    sound.RollOffMaxDistance = maxRoll
    sound.RollOffMinDistance = minRoll
    sound.Looped = true
    sound:Play()
end

---====== Hàm xử lý Rush khi xuất hiện ======---
local function OnRushSpawned(rushModel)
    -- 1. Triệu hồi Invisible Entity đi kèm
    task.spawn(SpawnInvisible)

    -- 2. Thay đổi Jumpscare UI
    pcall(function()
        local jumpUI = localPlayer.PlayerGui.MainUI.Jumpscare.Jumpscare_Rush
        jumpUI.ImageLabel.Image = "rbxassetid://112559786447473"
        jumpUI.ImageLabelBig.Image = "rbxassetid://112559786447473"
    end)

    -- 3. Chỉnh sửa Rush Model (Visuals)
    local rushRoot = rushModel:FindFirstChild("RushNew")
    if rushRoot then
        local att = rushRoot:FindFirstChild("Attachment")
        
        -- Xóa âm thanh cũ
        if rushRoot:FindFirstChild("PlaySound") then rushRoot.PlaySound:Destroy() end
        if rushRoot:FindFirstChild("Footsteps") then rushRoot.Footsteps:Destroy() end

        if att then
            local particle = att:FindFirstChild("ParticleEmitter")
            local trail = att:FindFirstChild("BlackTrail")

            -- Đổi mặt chính (Particle)
            if particle then
                particle.Texture = "rbxassetid://112559786447473"
                particle.Size = NumberSequence.new(6)
                -- Clone thêm particle cho dày
                for i = 1, 10 do particle:Clone().Parent = att end
            end

            -- Đổi mặt đuôi (Trail)
            if trail then
                trail.Texture = "rbxassetid://112559786447473"
                trail.Size = NumberSequence.new(5)
                -- Đổi sang trắng (255,255,255) để hiện rõ mặt
                trail.Color = ColorSequence.new(Color3.fromRGB(255,255,255))
                -- Clone thêm trail
                for i = 1, 10 do trail:Clone().Parent = att end
            end

            -- Ánh sáng
            local light = att:FindFirstChild("PointLight") or Instance.new("PointLight", att)
            light.Color = Color3.fromRGB(255, 255, 255)
            light.Brightness = 4
            light.Range = 10
            light.Enabled = true
        end

        -- 4. Thêm âm thanh tùy chỉnh
        CustomGitSound(rushRoot, "https://github.com/vuivuiviu2/Pressure-/raw/refs/heads/main/Recording_19_1.mp3", 3, "xavui", 100, 350)
        CustomGitSound(rushRoot, "https://github.com/vuivuiviu2/Pressure-/raw/refs/heads/main/Recording_20_1_1.mp3", 5, "closevui", 10, 100)
    end
end

---====== Vòng lặp kiểm tra Rush ======---
task.spawn(function()
    local isProcessing = false
    
    while true do
        local rush = workspace:FindFirstChild("RushMoving")
        if rush and not isProcessing then
            isProcessing = true
            OnRushSpawned(rush)
            
            -- Chờ cho đến khi Rush biến mất hẳn
            repeat task.wait(0.5) until not workspace:FindFirstChild("RushMoving")
            isProcessing = false
        end
        task.wait(0.1)
    end
end)
